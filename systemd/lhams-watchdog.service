[Unit]
Description=LHAMS Python Watchdog Control Tower
After=network.target auditd.service clamd@scan.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /mail/lhams_project/agent/lhams_watchdog.py
Environment=LHAMS_WATCH_DIR=/mail/test_monitor
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
